# Create .gitignore with Node/Docker/DB essentials (paste this in via nano/vi or echo > .gitignore)
cat > .gitignore << EOF
# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Env secrets
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Builds
dist/
build/
.next/
.out/

# Logs
logs
*.log

# OS/Editor
.DS_Store
Thumbs.db
.vscode/
.idea/

# Docker
.dockerignore

# DB dumps (your refactored backups)
*.sql.dump
backups/

# Temp
*.swp
*.swo
EOF

# If node_modules or .env got committed (check: git ls-tree -r HEAD --name-only | grep -E "(node_modules|\.env)"), prune 'em
git rm -r --cached node_modules .env 2>/dev/null || true  # Safe; no-op if missing

# Stage, commit, and push (if gh create not run yet; otherwise git push)
git add .gitignore
git commit -m "Add .gitignore for clean Node/Docker repo"
gh repo create shadowcheck --public --source=. --remote=origin --push --description "Refactored SIGINT forensics platform for wireless analysis with PostGIS"
backups/
